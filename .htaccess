#################################################################################################
# ProcessWire .htaccess
#################################################################################################

# Override default 404 page
ErrorDocument 404 /index.php

# Turn on mod_rewrite
RewriteEngine On

# Deny access to protected directories
RewriteRule "(^|/)\.(?!well-known)" - [F]
RewriteRule "(^|/)(wire|site)/templates(-admin)?/|\.inc$" - [F]
RewriteRule "(^|/)site/assets/(cache|logs|backups|sessions|config|install)" - [F]
RewriteRule "(^|/)site/assets/files/\d+/(.*\.php)$" - [F]

# Block access to certain file types
<FilesMatch "\.(inc|info|module|sh|sql)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
  </IfModule>
</FilesMatch>

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !(favicon\.ico|robots\.txt)

# Route everything else to ProcessWire
RewriteRule ^(.*)$ index.php?it=$1 [L,QSA]

#################################################################################################
# 9A. HTTPS redirect — uncomment to force HTTPS
#################################################################################################
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

#################################################################################################
# Optional: Security headers
#################################################################################################
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

#################################################################################################
# Optional: Compression
#################################################################################################
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

#################################################################################################
# Optional: Browser caching
#################################################################################################
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
