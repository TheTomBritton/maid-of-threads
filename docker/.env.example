# Maid of Threads — Docker environment
COMPOSE_PROJECT_NAME=maid-of-threads

# Web server port (change if 8080 is in use)
WEB_PORT=8080

# Adminer (database admin UI) port
ADMINER_PORT=8081

# Database credentials
DB_NAME=mot_dev
DB_USER=mot_user
DB_PASS=mot_password
DB_ROOT_PASS=root_password
DB_PORT=3306

# Stripe (optional — for local cart/checkout testing)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
